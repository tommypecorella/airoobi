    { "source": "/airdrops/:id", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/api/airdrop-ssr?id=:id" },
    { "source": "/esplora", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/dapp.html" },
