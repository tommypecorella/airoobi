    { "source": "/portafoglio", "destination": "/home.html" },
    { "source": "/guadagni", "destination": "/home.html" },
    { "source": "/referral", "destination": "/home.html" },
    { "source": "/classifica", "destination": "/home.html" },
    { "source": "/vendi", "destination": "/home.html" },
    { "source": "/admin", "destination": "/home.html" },
    { "source": "/abo", "destination": "/abo.html" },
