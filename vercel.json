{
  "buildCommand": "",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/ads.txt", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/ads-app.txt" },
    { "source": "/ads.txt", "has": [{"type": "host", "value": "airoobi.app"}], "destination": "/ads-app.txt" },
    { "source": "/ads.txt", "destination": "/ads-com.txt" },
    { "source": "/sitemap.xml", "has": [{"type": "host", "value": "www.airoobi.com"}], "destination": "/sitemap-com.xml" },

    { "source": "/", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/landing.html" },
    { "source": "/blog", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/blog.html" },
    { "source": "/airdrops", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/dapp.html" },
    { "source": "/airdrops/:id", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/dapp.html" },
    { "source": "/esplora", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/dapp.html" },
    { "source": "/miei-airdrop", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/dapp.html" },
    { "source": "/proponi", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/dapp.html" },
    { "source": "/invita", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/dapp.html" },
    { "source": "/referral", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/dapp.html" },
    { "source": "/portafoglio", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/dapp.html" },
    { "source": "/archivio", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/dapp.html" },
    { "source": "/impara", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/dapp.html" },
    { "source": "/referral-dapp", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/dapp.html" },
    { "source": "/portafoglio-dapp", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/dapp.html" },
    { "source": "/login", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/login.html" },
    { "source": "/signup", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/signup.html" },
    { "source": "/abo", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/abo.html" },
    { "source": "/admin", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/abo.html" },
    { "source": "/explorer", "has": [{"type": "host", "value": "www.airoobi.app"}], "destination": "/explorer.html" },

    { "source": "/", "destination": "/home.html" },
    { "source": "/dapp", "destination": "/dapp.html" },
    { "source": "/airdrops", "destination": "/dapp.html" },
    { "source": "/airdrops/:id", "destination": "/dapp.html" },
    { "source": "/esplora", "destination": "/dapp.html" },
