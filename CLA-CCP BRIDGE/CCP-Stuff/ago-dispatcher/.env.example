# Copia in `.env` accanto (chmod 600, NON committare). La anon key agora è un BEARER SECRET.
AGORA_URL=https://tktuwboayqqimdhsrnap.supabase.co
AGORA_KEY=__incolla_qui_la_anon_key_agora__

# --- GATE di sicurezza (entrambi vanno aperti per spawnare davvero) ---
AGO_DRY_RUN=1                 # 1 = logga soltanto (default). 0 = spawn reale di claude -p. (agoctl live)
# toggle /ago ON/OFF = file state/ago.state (agoctl on|off). Default OFF.

# --- FRENI (LOCK) ---
AGO_WAKE_CAP_PER_HOUR=20      # §6c cap anti-runaway
AGO_RAM_MIN_MB=400           # §6e RAM-guard (Pi 1.8GB): sotto soglia → coda
AGO_WAKE_TIMEOUT=240         # amendment ROBY: timeout per-wake in s (anti-hang; < TimeoutStartSec=600)
# serializzazione (§6d) = flock, sempre attiva. batch (§6b) = 1 wake/tutti i pendenti, sempre.
# handled-guard (amendment ROBY): il dispatcher NON marca handled; ROBLOCK marca da sé via roblock_bus.mjs.

# --- routing deterministico (§3) ---
AGO_WAKEABLE=roblock,aro      # agenti instradabili (aro off-Pi v1 = solo log)
AGO_CH_ROBLOCK=marketing      # canali di competenza ROBLOCK (oltre alla mention @roblock)
AGO_CH_ARO=                   # vuoto = solo mention

# --- infra ---
ROBLOCK_DIR=/home/drskeezu/roblock   # dir identità ROBLOCK (CLAUDE.md + roblock_wake.sh)
# NODE_BIN=node                       # override se node non è in PATH del servizio
